# Sample environment for docker-compose. Copy to .env and fill in the secrets.
# DO NOT COMMIT .env. The values below are placeholders only.

# === one-api (existing) ===
PORT=3000
DEBUG=false
# HTTPS_PROXY=http://localhost:7890
# Session cookie secret; use any long random string. Mandatory in multi-node.
SESSION_SECRET=

# === Shared between one-api and payment-service (PR #1 of payment) ===
# Used to sign requests from payment-service to one-api's /api/internal/topup.
# Generate with:  openssl rand -hex 32
# BOTH services must read the SAME value.
INTERNAL_API_SECRET=

# === payment-service (PR #2 of payment) ===
# Xendit dashboard -> Settings -> Developers -> API Keys -> Secret Key
# For local testing, use the DEVELOPMENT key (prefix "xnd_development_").
XENDIT_SECRET_KEY=
# Xendit API endpoint. Test/sandbox uses the same URL; the key prefix decides mode.
XENDIT_BASE_URL=https://api.xendit.co
# Public URL the payment-service is reachable at. Used in operator docs and
# in the URL you register with Xendit for webhooks.
PAYMENT_BASE_URL=http://localhost:3001
# Logging.
LOG_LEVEL=info        # debug / info / warn / error
LOG_FORMAT=json       # json (prod) / console (dev)
