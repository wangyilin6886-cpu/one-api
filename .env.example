# Sample environment for docker-compose. Copy to .env and fill in the secrets.
# DO NOT COMMIT .env. Values below are placeholders only.

# === one-api (existing) ===
PORT=3000
DEBUG=false
# Session cookie secret; use any long random string. Mandatory in multi-node.
SESSION_SECRET=

# === Shared between one-api and payment-service (PR #1) ===
# Signs requests from payment-service to one-api's /api/internal/topup.
# Generate with:  openssl rand -hex 32
# BOTH services must read the SAME value.
INTERNAL_API_SECRET=

# === payment-service (Polar / MoR for global card payments) ===
# Polar dashboard -> Settings -> Developers -> Access Tokens.
# Format: polar_oat_*
# Use the SANDBOX token (POLAR_SANDBOX=true) for testing.
POLAR_ACCESS_TOKEN=

# When true, payment-service talks to sandbox-api.polar.sh. Set to false for prod.
POLAR_SANDBOX=true

# Public URL the payment-service is reachable at. Used in operator docs and
# in the URL you register with Polar for the webhook endpoint.
PAYMENT_BASE_URL=http://localhost:3001

# Logging.
LOG_LEVEL=info        # debug / info / warn / error
LOG_FORMAT=json       # json (prod) / console (dev)

# ===================================================================
# Runtime-editable values live in the payment_config table:
#   - polar_webhook_secret      (REQUIRED before webhooks work)
#   - polar_organization_id     (REQUIRED before checkouts work)
#   - polar_topup_product_id    (REQUIRED before checkouts work)
#   - min_topup_usd_cents       (default 500 = $5)
#   - max_topup_usd_cents       (default 200000 = $2000)
#   - order_expiry_minutes      (default 30)
#   - checkout_success_url      (Polar redirect target)
#   - checkout_cancel_url       (Polar redirect target)
#   - alert_email               (needs_manual_review notifications)
#
# Edit via SQL after first startup:
#   docker exec -it mysql mysql -u oneapi -p oneapi_payment
#   > UPDATE payment_config SET config_value='polar_xxx'
#     WHERE config_key='polar_webhook_secret';
# ===================================================================
